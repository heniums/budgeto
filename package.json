{
  "name": "budgeto",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Budgeto - personal finance & budgeting PWA with TypeScript, React, Express and PostgreSQL.",
  "scripts": {
    "dev": "concurrently -n db,server,client -c blue,green,magenta \"npm:db\" \"npm:dev:server\" \"npm:dev:client\"",
    "db": "node scripts/start-db.mjs",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:client": "vite --config client/vite.config.ts",
    "build": "tsc -p tsconfig.json --noEmit && vite build --config client/vite.config.ts",
    "start": "tsx server/src/index.ts",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "test": "CI=true vitest run",
    "test:watch": "vitest",
    "test:coverage": "CI=true vitest run --coverage"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.33.0",
    "drizzle-kit": "^0.24.0",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.5.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/supertest": "^6.0.2",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.0.5",
    "concurrently": "^8.2.2",
    "embedded-postgres": "17.10.0-beta.17",
    "eslint": "^9.9.0",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.1.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.5"
  }
}
